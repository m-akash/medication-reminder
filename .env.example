# Copy to .env and fill in real values. NEVER commit .env.

# ── SQL Server ───────────────────────────────────────────────────────
# Strong password required by SQL Server (8+ chars, upper/lower/digit/symbol).
SQL_PASSWORD=ChangeMe_Strong_Pass1!
SQL_DATABASE=MedicineReminderDb
SQL_PORT=1433

# ── App ──────────────────────────────────────────────────────────────
APP_PORT=8080

# ── OpenIddict signing/encryption certificate ────────────────────────
# Path on the HOST to your openiddict.pfx (mounted read-only into the container).
OPENIDDICT_PFX_PATH=./certs/openiddict.pfx
# Password that pfx was exported with.
OPENIDDICT_PFX_PASSWORD=your-pfx-password

# ── SMTP (Settings:Abp.Mailing.Smtp.*) ───────────────────────────────
SMTP_FROM_ADDRESS=yourmedicationreminder@gmail.com
SMTP_FROM_NAME=Medicine Reminder
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmedicationreminder@gmail.com
SMTP_PASSWORD=your-app-password
